{
  "compilerOptions": {
    "composite": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"]
    }
  },
  "extends": "../tsconfig.json",
  "include": [
    ".size-limit.ts",
    "src",
    "tests",
    "vite/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "package.json"
  ]
}
